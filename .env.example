# Valve Datasheet UI - Environment Configuration

# Main Backend API URL
VITE_API_URL=http://127.0.0.1:8000/api

# ML Prediction Service URL (same backend in unified local setup)
VITE_ML_API_URL=http://127.0.0.1:8000/api

# User Management API URL (Authentication & RBAC)
# Consolidated backend exposes auth/users/roles/projects on the same 8000 API.
VITE_USER_MGMT_API=http://localhost:8000/api

# PMS Generator API (Piping Material Specification — new backend)
# The PMS AI Agent talks to this base URL for chat, session history, and
# Excel downloads. Local dev: http://localhost:8004/api
VITE_PMS_API_URL=https://pms-generator-final.onrender.com/api

# Revision Workflow API
# Mounted inside the main backend at /api/revision. Override only if you run
# the revision module on a different host. By default it derives from
# VITE_API_URL above.
# VITE_REVISION_API_URL=http://localhost:8000/api/revision
